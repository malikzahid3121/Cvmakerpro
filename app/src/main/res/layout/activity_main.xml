<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:padding="20dp">


    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CVMakerPro"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#0B1F3A"
            android:gravity="center"/>


        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Build Your Professional CV"
            android:textSize="16sp"
            android:textColor="#777777"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="25dp"/>


        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Full Name"
            android:padding="15dp"
            android:background="@drawable/edittext_background"
            android:layout_marginBottom="12dp"/>


        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Email Address"
            android:inputType="textEmailAddress"
            android:padding="15dp"
            android:background="@drawable/edittext_background"
            android:layout_marginBottom="12dp"/>


        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Phone Number"
            android:inputType="phone"
            android:padding="15dp"
            android:background="@drawable/edittext_background"
            android:layout_marginBottom="12dp"/>


        <EditText
            android:id="@+id/etEducation"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:hint="Education"
            android:gravity="top"
            android:padding="15dp"
            android:background="@drawable/edittext_background"
            android:layout_marginBottom="12dp"/>


        <EditText
            android:id="@+id/etExperience"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:hint="Work Experience"
            android:gravity="top"
            android:padding="15dp"
            android:background="@drawable/edittext_background"
            android:layout_marginBottom="12dp"/>


        <EditText
            android:id="@+id/etSkills"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Skills"
            android:gravity="top"
            android:padding="15dp"
            android:background="@drawable/edittext_background"
            android:layout_marginBottom="20dp"/>


        <Button
            android:id="@+id/btnTemplate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Choose CV Template"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>


        <Button

            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Create Professional CV"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_primary"/>


    </LinearLayout>

</ScrollView>