<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CV Maker Pro"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <EditText android:id="@+id/etName" android:hint="Full Name" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text"/>
        <EditText android:id="@+id/etEmail" android:hint="Email" android:inputType="textEmailAddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text"/>
        <EditText android:id="@+id/etPhone" android:hint="Phone" android:inputType="phone" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text"/>
        <EditText android:id="@+id/etEducation" android:hint="Education" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:minLines="3" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text"/>
        <EditText android:id="@+id/etExperience" android:hint="Work Experience" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:minLines="3" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text"/>
        <EditText android:id="@+id/etSkills" android:hint="Skills" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:minLines="2" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text"/>

        <Button
            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Download PDF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#1976D2"
            android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>